{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "width": "container",
    "title":"Far Eastern Curlew Annual migration path",
    "projection": {"type": "equirectangular"},
    "config": {
        "view": {"stroke":"transparent"}
    },
    "background":"#ffffff",
    "layer": [
      {
        "data": {
          "url": "https://raw.githubusercontent.com/Snowy1235/FIT2179/main/shapefiles/world.topojson",
          "format": {"type": "topojson", "feature": "ne_110m_admin_0_countries"}
        },
        
        "mark": {"type": "geoshape", "fill": "#d9d9d9", "stroke": "#797979"}
      },
      {
        "data": {
          "url": "https://raw.githubusercontent.com/Snowy1235/FIT2179/main/data/CurlewTracking.csv"
        },
        "transform": [
          {"filter":"datum.algorithm_marked_outlier == '' & datum.tag_local_identifier == 40961"}
        ],
        "mark": {"type": "line"},
        "encoding": {
          "longitude": {"field": "location-long", "type": "quantitative"},
          "latitude": {"field": "location-lat", "type": "quantitative"},
          "order":{"field":"timestamp","type": "temporal"}
        }
      }
    ]
  }
