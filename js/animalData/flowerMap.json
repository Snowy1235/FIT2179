{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "width": "container",
    "height":400,
    "projection": {"type": "equirectangular"},
    "config": {
        "view": {"stroke":"transparent"}
    },
    "params": [
      {
        "name": "taxonomicFilter",
        "value": [
          "Bird",
          "Amphibian",
          "Plant",
          "Mammal"
        ]
      },
      {
        "name": "priorityOnly",
        "value": false
      }
    ],
    "background": null,
    "layer": [
      {
        "data": {
          "url": "https://raw.githubusercontent.com/Snowy1235/FIT2179/main/shapefiles/SW.topojson",
          "format": {"type": "topojson", "feature": "SW"}
        },
        
        "mark": {"type": "geoshape", "fill": "#d9d9d9", "stroke": "#797979"}
      },
      {
        "data": {
          "url": "https://raw.githubusercontent.com/Snowy1235/FIT2179/main/shapefiles/flowershape.topojson",
          "format": {"type": "topojson", "feature": "a"}
        },
        "mark": {"type": "geoshape", "fill": "#933b3b", "stroke": "#9a3030"}
      }
    ]
  }