{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "width": "container",
    "height":400,
    "projection": {"type": "equirectangular"},
    "config": {
        "view": {"stroke":"transparent"}
    },
    "background": null,
    "layer": [
      {
        "data": {
          "url": "https://raw.githubusercontent.com/Snowy1235/FIT2179/main/shapefiles/Aust-region-shapemap.topojson",
          "format": {"type": "topojson", "feature": "SA3_2021_AUST_GDA2020"}
        },
        
        "mark": {"type": "geoshape", "fill": "#d9d9d9", "stroke": "#797979"}
      },
      {
        "data": {
          "url": "https://raw.githubusercontent.com/Snowy1235/FIT2179/main/data/tsx-aggregated-data.csv"
        },
        "params": [
          {
            "name": "speciesSelect",
            "select": {
              "type": "point",
              "fields": ["CommonName"]
            }
          }
        ],
        "transform": [
          {"calculate": "replace(datum.Binomial,'_',' ')", "as":"sciName"},
          {"filter":"datum.RegionCentroidLongitude > 111 & datum.RegionCentroidLongitude < 155 & datum.TaxonomicGroup=='Amphibians' & datum.NationalPriorityTaxa==1"}
        ],
        "mark": {"type": "circle", "tooltip": {"content": "data"}},
        "encoding": {
          "longitude": {"field": "RegionCentroidLongitude", "type": "quantitative"},
          "latitude": {"field": "RegionCentroidLatitude", "type": "quantitative"},
          "color":{
            "field":"CommonName",
            "scale":{"scheme":"paired"}
          },
          "opacity": {
            "condition": {
              "param": "speciesSelect",
              "value": 1
            },
            "value": 0.18
          },
          "size":{
            "field":"IUCNStatus",
            "sort":["Critically Endangered","Endangered", "Vulnerable","Near Threatened","Least Concern"],
            "title":"Endangerment status",
            "type": "nominal",
            "scale": {
              "domain":["Critically Endangered","Endangered", "Vulnerable","Near Threatened","Least Concern"],
              "range":[100,400]
            }
          },
          "tooltip":[
            {"field":"CommonName","title":"Name"},
            {"field":"sciName","title":"Scientific Name"},
            {"field":"Population","title":"Estimated population"},
            {"field":"IUCNStatus", "title":"Vulnerability"}
          ]
        }
      }
    ]
  }