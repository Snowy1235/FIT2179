{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "width": "container",
    "height":400,
    "projection": {"type": "equirectangular"},
    "config": {
        "view": {"stroke":"transparent"}
    },
    "params": [
      {
        "name": "taxonomicFilter",
        "value": [
          "Bird",
          "Amphibian",
          "Plant",
          "Mammal"
        ]
      },
      {
        "name": "priorityOnly",
        "value": false
      }
    ],
    "background": null,
    "layer": [
      {
        "data": {
          "url": "https://raw.githubusercontent.com/Snowy1235/FIT2179/main/shapefiles/Aust-region-shapemap.topojson",
          "format": {"type": "topojson", "feature": "SA3_2021_AUST_GDA2020"}
        },
        
        "mark": {"type": "geoshape", "fill": "#d9d9d9", "stroke": "#797979"}
      },
      {
        "data": {
          "url": "https://raw.githubusercontent.com/Snowy1235/FIT2179/main/data/tsx-aggregated-data.csv"
        },
        "params": [
          {
            "name": "speciesSelect",
            "select": {
              "type": "point",
              "fields": ["CommonName"]
            }
          }
        ],
        "transform": [
          {"calculate": "replace(datum.Binomial,'_',' ')", "as":"sciName"},
          {
            "filter": "indexof(taxonomicFilter, datum.TaxonomicGroup) >= 0"
          },
          {
            "filter": "!priorityOnly || datum.NationalPriorityTaxa == 1"
          },
          {"filter":"datum.RegionCentroidLongitude > 111 & datum.RegionCentroidLongitude < 155"}
        ],
        "mark": {"type": "circle", "tooltip": {"content": "data"},"size":100},
        "encoding": {
          "longitude": {"field": "RegionCentroidLongitude", "type": "quantitative"},
          "latitude": {"field": "RegionCentroidLatitude", "type": "quantitative"},
          "color":{
            "field":"IUCNStatus",
            "sort":["Least Concern","Near Threatened", "Vulnerable","Endangered","Critically Endangered"],
            "title":"Endangerment status",
            "type": "nominal",
            "scale": {
              "domain":["Least Concern","Near Threatened", "Vulnerable","Endangered","Critically Endangered"],
              "range": ["#1a9641","#a6d96a","#ffffbf","#fdae61","#d7191c"]
            },
            "legend":{"offset":-80}
          },
          "opacity": {
            "condition": {
              "param": "speciesSelect",
              "value": 1
            },
            "value": 0.1
          },
          "size": {
            "condition": {
              "param": "speciesSelect",
              "value": 100
            },
            "value": 20
          },
          "tooltip":[
            {"field":"CommonName","title":"Name"},
            {"field":"sciName","title":"Scientific Name"},
            {"field":"Population","title":"Estimated population"},
            {"field":"IUCNStatus", "title":"Vulnerability"}
          ]
        }
      }
    ]
  }